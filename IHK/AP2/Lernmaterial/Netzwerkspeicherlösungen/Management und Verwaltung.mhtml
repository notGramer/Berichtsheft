#nprogress .peg { display: block; position: absolute; right: 0px; width: 10=
0px; height: 100%; box-shadow: rgb(75, 85, 99) 0px 0px 10px, rgb(75, 85, 99=
) 0px 0px 5px; opacity: 1; transform: rotate(3deg) translate(0px, -4px); }

#nprogress .spinner { display: block; position: fixed; z-index: 1031; top: =
15px; right: 15px; }

#nprogress .spinner-icon { width: 18px; height: 18px; box-sizing: border-bo=
x; border-width: 2px; border-style: solid; border-color: rgb(75, 85, 99) tr=
ansparent transparent rgb(75, 85, 99); border-image: initial; border-radius=
: 50%; animation: 400ms linear 0s infinite normal none running nprogress-sp=
inner; }

.nprogress-custom-parent { overflow: hidden; position: relative; }

.nprogress-custom-parent #nprogress .spinner, .nprogress-custom-parent #npr=
ogress .bar { position: absolute; }

@-webkit-keyframes nprogress-spinner {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes nprogress-spinner {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
