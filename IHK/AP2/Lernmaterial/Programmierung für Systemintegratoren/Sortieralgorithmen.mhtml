e(spalte, -1, -1)):\n        if brett[i][j] =3D=3D 1:\n            return F=
alse\n\n    # \u00dcberpr\u00fcfe untere linke Diagonale\n    for i, j in z=
ip(range(zeile, n, 1), range(spalte, -1, -1)):\n        if brett[i][j] =3D=
=3D 1:\n            return False\n\n    return True\n\ndef loese_n_damen(br=
ett, spalte, n):\n    # Wenn alle Damen platziert sind, erfolg\n    if spal=
